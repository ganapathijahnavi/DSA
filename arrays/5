Move all zeroes to the end
Program:
ar = [0,1,0,3,12] 
# → [1,3,12,0,0]
def move_zeroes_to_end(ar):
    count = 0
    for i in range(len(ar)):
        if ar[i] != 0:
            ar[count] = ar[i]
            count += 1
    while count < len(ar):
        ar[count] = 0
        count += 1
    return ar
print(move_zeroes_to_end(ar))
