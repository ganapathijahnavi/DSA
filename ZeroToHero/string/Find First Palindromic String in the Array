def firstPalindrome(self, words: List[str]) -> str:
        def palindrome(s):
            l, r = 0, len(s)-1
            while(l < r):
                if s[l] != s[r]:
                    return False
                else:
                    l += 1
                    r -= 1
            return True
        for i in words:
            if palindrome(i):
                return i
        return ""
