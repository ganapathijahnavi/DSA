# Left Rotate the Array by One
#long and not efficient
arr = list(map(int,input().split(" ")))
def rev(arr,start,end):
  while(start < end):
    arr[start], arr[end] = arr[end], arr[start]
    start += 1
    end -= 1
  return arr
n = len(arr)
rev(arr,0,n-1)
rev(arr,0,n-2)
print(arr)

