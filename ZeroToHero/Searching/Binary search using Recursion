def binary_search(arr,ele,l,r):
    mid = (l + r) // 2
    if l > r:
        return -1
    if arr[mid] == ele:
        return mid
    if arr[mid] > ele:
        return binary_search(arr,ele, l, mid-1)
    else:
        return binary_search(arr,ele, mid+1,r)
arr = [1,2,3,4,5,6,7]
ele = 1
print(binary_search(arr,ele,0,len(arr)-1))
